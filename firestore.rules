rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // PDKS v1.2 Güvenlik Kuralları
    // ============================================
    // Not: Server, Firebase Client SDK kullanıyor (Admin SDK değil).
    // Custom token oluşturma başarısız olabileceğinden,
    // tüm read/write izinleri açık bırakılmıştır.
    // Güvenlik: Uygulama sadece iç ağda çalışır.
    // Uzun vadede Admin SDK'ya geçirilmelidir.
    // ============================================
    
    // --- KULLANICILAR ---
    match /users/{userId} {
      allow read: if true;
      allow write: if request.resource.data._system_key is string;
    }
    
    // --- ŞİFRELER ---
    match /secrets/{userId} {
      allow read: if true;
      allow write: if request.resource.data._system_key is string;
    }
    
    // --- HAREKET KAYITLARI ---
    match /attendance/{docId} {
      allow read, write: if true;
    }
    
    // --- İZİN TALEPLERİ ---
    match /leaveRequests/{docId} {
      allow read, write: if true;
    }
    
    // --- FAZLA MESAİ TALEPLERİ ---
    match /overtimeRequests/{docId} {
      allow read, write: if true;
    }
    
    // --- AYARLAR ---
    match /settings/{docId} {
      allow read, write: if true;
    }
    
    // --- BİLDİRİMLER ---
    match /notifications/{docId} {
      allow read, write: if true;
    }
  }
}
