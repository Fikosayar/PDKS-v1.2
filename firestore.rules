rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // PDKS v1.2 Güvenlik Kuralları
    // ============================================
    // Not: Server, Firebase Client SDK kullanıyor (Admin SDK değil).
    // Bu yüzden bazı collection'larda unauthenticated erişim gerekli.
    // Uzun vadede server Admin SDK'ya geçirilmeli.
    // ============================================
    
    // --- KULLANICILAR ---
    // Server login sırasında auth olmadan okuma yapıyor
    match /users/{userId} {
      allow read: if true;
      // Yazma: sadece _system_key içeren istekler (backend)
      allow write: if request.resource.data._system_key is string;
    }
    
    // --- ŞİFRELER ---
    // Server login sırasında şifre doğrulaması için okuma gerekli
    match /secrets/{userId} {
      allow read: if true;
      allow write: if request.resource.data._system_key is string;
    }
    
    // --- HAREKET KAYITLARI ---
    match /attendance/{docId} {
      // Giriş yapmış kullanıcılar kendi kayıtlarını okuyabilir
      allow read: if request.auth != null;
      // Yazma: giriş yapmış kullanıcılar (client) veya server
      allow create: if request.auth != null;
      // Güncelleme/Silme: server endpoint'leri üzerinden
      allow update, delete: if true;
    }
    
    // --- İZİN TALEPLERİ ---
    match /leaveRequests/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // --- FAZLA MESAİ TALEPLERİ ---
    match /overtimeRequests/{docId} {
      allow read: if request.auth != null;
      // create: hem client hem server yazabilir
      allow write: if request.auth != null || true;
    }
    
    // --- AYARLAR ---
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // --- BİLDİRİMLER ---
    match /notifications/{docId} {
      allow read: if request.auth != null;
      // Server auth olmadan bildirim oluşturuyor
      allow write: if true;
    }
  }
}
